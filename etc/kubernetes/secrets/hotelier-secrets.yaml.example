apiVersion: v1
kind: Secret
metadata:
  name: hotelier-secrets
  namespace: hotelier
type: Opaque
stringData:
  # ── JWT ──
  Jwt__Key: <CHANGE_ME_32_chars_minimum>
  Jwt__Issuer: hotelier-identity
  Jwt__Audience: hotelier
  # ── RabbitMQ ──
  Rabbit__Password: <CHANGE_ME>
  # ── PostgreSQL ──
  POSTGRES_USER: <CHANGE_ME>
  POSTGRES_PASSWORD: <CHANGE_ME>
  # ── MongoDB ──
  MONGO_USER: <CHANGE_ME>
  MONGO_PASSWORD: <CHANGE_ME>
