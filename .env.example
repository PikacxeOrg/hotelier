# ---------------------------------------------
# Hotelier – Environment Variables
# ---------------------------------------------
# Copy to .env and fill in real values.
# .env is gitignored and must never be committed.
#
# Used by:
#   - docker-compose.dev.yml     (via COMPOSE_FILE below)
#   - docker-compose.swarm.yml   (via swarm-deploy.sh)
#   - etc/scripts/seed-data.sh   (optional)
# ---------------------------------------------

# -- Docker Compose --
COMPOSE_FILE=docker-compose.dev.yml

# -- PostgreSQL --
POSTGRES_USER=hotelier
POSTGRES_PASSWORD=hotelier

# -- MongoDB --
MONGO_USER=hotelier
MONGO_PASSWORD=hotelier

# -- RabbitMQ --
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=guest

# -- JWT (identity-service) --
JWT_KEY=super-secret-dev-key-change-me-in-prod-32chars!
JWT_ISSUER=hotelier-identity
JWT_AUDIENCE=hotelier

# -- Grafana --
GF_ADMIN_PASSWORD=admin

# -- Swarm / Registry --
REGISTRY=localhost:5000
TAG=latest
